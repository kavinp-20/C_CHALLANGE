#include<stdio.h>

int main(){
    float a,b,bonus,totalSalary;
    scanf("%f %f",&a,&b);
    if(a<=30000 && b>=5){
        bonus=a*0.2;
        
    }
    else if(a>=30000 && b>=5){
        bonus=a*0.1;
    }
    totalSalary = a+bonus;
    printf("\n a         : Rs. %.2f", a);
    printf("\nBonus Amount    : Rs. %.2f", bonus);
    printf("\nTotal Salary    : Rs. %.2f", totalSalary);

    return 0;
}
