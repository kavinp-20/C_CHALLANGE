#include <stdio.h>

int main() {
    int number;

    // Input from user
    printf("Enter an integer: ");
    scanf("%d", &number);

    // If-Else Condition
    if (number > 0) {
        printf("%d is a Positive number.\n", number);
    }
    else if (number < 0) {
        printf("%d is a Negative number.\n", number);
    }
    else {
        printf("The number is Zero.\n");
    }

    return 0;
}
