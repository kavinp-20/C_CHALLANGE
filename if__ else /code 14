#include <stdio.h>

int main()
{
    int units;
    float bill;

    printf("Enter the number of units consumed: ");
    scanf("%d", &units);

    if (units <= 100)
    {
        bill = units * 1.50;
    }
    else if (units <= 200)
    {
        bill = units * 2.50;
    }
    else if (units <= 300)
    {
        bill = units * 4.00;
    }
    else
    {
        bill = units * 6.00;
    }

    printf("\nUnits Consumed : %d", units);
    printf("\nTotal Bill     : Rs. %.2f\n", bill);

    return 0;
}
